# Supabase public client config.
# Safe to expose in browser code when Row Level Security is configured.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only Supabase config for production deploys.
# Never expose this key in browser code. Use only in server routes/actions.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_or_service_role_xxx

# Backward-compatible aliases accepted by the app.
SUPABASE_SECRET_KEY=sb_secret_or_service_role_xxx

# App storage conventions
SUPABASE_CHARACTER_IMAGES_BUCKET=character-images
