{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/_serverFn/(.*)",
      "destination": "/api/index.mjs"
    },
    {
      "source": "/((?!api/|assets/|robots.txt).*)",
      "destination": "/api/index.mjs"
    }
  ]
}
